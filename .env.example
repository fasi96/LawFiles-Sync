# LawFiles-Sync — environment variables
#
# Copy this file to `.env` and fill in real values for local development:
#     cp .env.example .env
#
# For production: set every variable below in
#     Vercel Project → Settings → Environment Variables
#     (scope: Production + Preview + Development)
#
# Never commit `.env`. It is already listed in .gitignore.

# ---------------------------------------------------------------------------
# Gravity Forms REST API v2
# ---------------------------------------------------------------------------
# Where to find these:
#   WP Admin → Forms → Settings → REST API → Add Key
#   Set permissions to "Read" (we only fetch entries, never mutate).
#
# GF_BASE_URL: the WordPress site root, no trailing slash.
# GF_FORM_ID:  numeric form ID. The bankruptcy questionnaire appears to be 8
#              based on the export JSON in the converter repo — confirm in
#              WP Admin → Forms → (form name) → URL contains ?id=<n>.
GF_BASE_URL=https://fleysherlaw.com
GF_FORM_ID=8
GF_CONSUMER_KEY=ck_replace_me
GF_CONSUMER_SECRET=cs_replace_me

# ---------------------------------------------------------------------------
# Dropbox app (scoped access, refresh-token OAuth)
# ---------------------------------------------------------------------------
# Where to find these:
#   1. https://www.dropbox.com/developers/apps → Create app
#        - API:         Scoped access
#        - Type:        App folder  (recommended — sandboxed)
#                       OR Full Dropbox if the target folder must live
#                       outside an app sandbox.
#        - Name:        LawFiles-Sync (or anything unique)
#   2. On the app's Permissions tab, enable:
#        files.content.write
#        files.content.read
#        files.metadata.write
#        files.metadata.read
#      Click Submit. (Permission changes invalidate existing tokens — do
#      this BEFORE generating the refresh token.)
#   3. App key + App secret are on the Settings tab.
#   4. Refresh token: run `python scripts/dropbox_auth.py` locally once.
#      It prints a URL, you paste the auth code back, it prints the refresh
#      token. Save that here. Refresh tokens do not expire unless revoked.
#
# DROPBOX_TARGET_FOLDER: path inside Dropbox where .bci files and the
#   last_run.json state file are written. For an "App folder" app, this is
#   relative to the app's sandbox (e.g. "/" puts files at the sandbox root).
#   For a "Full Dropbox" app, use an absolute path like "/Fleysher BCI Imports".
DROPBOX_APP_KEY=replace_me
DROPBOX_APP_SECRET=replace_me
DROPBOX_REFRESH_TOKEN=replace_me
DROPBOX_TARGET_FOLDER=/BCI Files

# ---------------------------------------------------------------------------
# Vercel cron + manual trigger auth
# ---------------------------------------------------------------------------
# CRON_SECRET protects both the scheduled cron endpoint and the manual
# trigger endpoint. Vercel cron sends this in the Authorization header
# automatically when configured via vercel.json. The manual endpoint
# requires the same value via ?secret=... or Authorization: Bearer ...
#
# Generate locally:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=replace_me_with_a_long_random_string

# ---------------------------------------------------------------------------
# Behaviour flags (optional — defaults are safe)
# ---------------------------------------------------------------------------
# FIRST_RUN_BACKFILL: if last_run.json does not exist in Dropbox, what window
#   should the first run cover?
#     "none"        — treat last_run = now; only future entries (default, safest)
#     "YYYY-MM-DD"  — backfill from this date forward (one-time mass upload)
FIRST_RUN_BACKFILL=none

# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
